# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Supabase — for LOCAL development you do NOT edit these by hand: run
# `./scripts/dev.sh db:up`, which writes the local stack's URL + anon key to
# `.env.development.local` (loaded ahead of `.env` in dev). Leave these pointed
# at your remote/hosted project for production builds.
# If you add client-side keys later, prefix them EXPO_PUBLIC_ so Expo inlines them
# (no babel plugin needed). Do NOT reintroduce react-native-dotenv / `@env` — its
# babel plugin suppresses babel-preset-expo transforms and breaks Reanimated worklets.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
