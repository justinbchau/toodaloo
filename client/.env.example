# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# These are read at build/runtime. EXPO_PUBLIC_* values are embedded in the app
# bundle (safe for the Supabase anon key, which is protected by RLS). For EAS
# builds, set the same variables as EAS environment variables (see supabase and
# the "Native builds" section of the README).

# Supabase — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Google Maps (Android only). Required for react-native-maps to render the map on
# Android. Create a key in Google Cloud Console, enable "Maps SDK for Android",
# and restrict it to the app's package name + signing SHA-1.
# iOS uses Apple Maps and does not need this.
GOOGLE_MAPS_ANDROID_API_KEY=
